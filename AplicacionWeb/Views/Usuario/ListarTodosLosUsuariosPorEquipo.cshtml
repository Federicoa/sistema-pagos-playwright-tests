@using Dominio;

@if (ViewBag.Error != null)
{
    <div class="alert alert-danger">
        @ViewBag.Error
    </div>
}


<h1>Listado de Usuarios por Equipo</h1>
<br />
<br />


<form method="post">
    Nombre de Equipo : <input type="text" name="equipo" style="padding-left: 10px; width: 300px;" />
    <br />
    <br />
    <div class="alert alert-info mt-3 mb-3" role="alert">Actualmente nuestros equipos existentes son Marketing, Ventas, TI y Administracion</div>
    <br />
    <br />
    
    <input type="submit" value="Buscar Usuarios" />
    <br />
    <br />
    

    @if (ViewBag.Usuarios != null)
    {
        <h2>Usuarios encontrados:</h2>
        <br />
        <br />
        <table class="table table-bordered table-striped">
            <thead>
                <tr>
                    <th>Nombre</th>
                    <th>Apellido</th>
                    <th>Email</th>                      
                </tr>
            </thead>
            <tbody>
                @foreach (Usuario usuario in ViewBag.Usuarios)
                {
                    <tr>
                        <td>@usuario.NombreUsuario</td>
                        <td>@usuario.Apellido</td>
                        <td>@usuario.Email</td>
                    </tr>
                }
            </tbody>
        </table>
    }
    
</form>

