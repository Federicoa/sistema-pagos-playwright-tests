@using Dominio;

@if (ViewBag.Error != null)
{
    <div class="alert alert-danger">
        @ViewBag.Error
    </div>
}


<h1>Agregar Pago Único</h1>
<br />
<br />


<form method="post">
    <br />
    <br />
    Método de Pago
    <select name="metodoDePago" class="form-select" style="padding-left: 10px; width: 300px;">
        @foreach (var metodo in Enum.GetValues(typeof(MetodoDePago)))
        {
            <option value="@metodo">@metodo</option>
        }
    </select>
    <br />
    <br />
    Tipo de Gasto
    <select name="tipoDeGasto" class="form-select" style="padding-left: 10px; width: 300px;">
        @foreach (TipoDeGasto tg in ViewBag.TiposGasto)
        {
            <option value="@tg.Nombre">@tg.Nombre</option>
        }
    </select>
    <br />
    <br />
    Descripción
    <br />
    <input type="text" name="descripcion" style="padding-left: 10px; width: 300px;" />
    <br />
    <br />
    Monto
    <br />
    <input type="number" name="montoPago" style="padding-left: 10px; width: 300px;" />
    <br />
    <br />
    Fecha
    <br />
    <input type="date" name="fechaPago" style="padding-left: 10px; width: 300px;" />
    <br />
    <br />
    Número de Recibo
    <br />
    <input type="number" name="numeroRecibo" style="padding-left: 10px; width: 300px;" />
    <br />
    <br />
   
    <br />

    <button type="submit" class="btn btn-primary">Guardar Pago</button>
</form>
